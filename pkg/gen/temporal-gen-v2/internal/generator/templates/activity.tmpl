{{- $reqType := "" -}}
{{- if .Options.GenerateWrapper -}}
	{{- $reqType = printf "%sRequest" (.Name | ToPascal) -}}
{{- else -}}
	{{- $reqType = .InputType -}}
{{- end -}}

{{- if .Options.GenerateWrapper}}
type {{$reqType}} struct {
{{- range .Params}}
	{{.ExportedName}} {{.Type}} `validate:"required"`
{{- end}}
}

// {{if .Options.WrapperPrefix}}{{.Options.WrapperPrefix}}{{end}}{{.Name | ToPascal}} is a wrapper for the {{.OriginalName}} activity
func (a {{.Receiver}}) {{if .Options.WrapperPrefix}}{{.Options.WrapperPrefix}}{{end}}{{.Name | ToPascal}}(ctx context.Context, req {{$reqType}}) ({{if .OutputType}}{{.OutputType}}, {{end}}error) {
	return a.{{.OriginalName}}(ctx, {{range .Params}}req.{{.ExportedName}}, {{end}})
}
{{- end}}

// Await{{.Name | ToPascal}} is a wrapper for the {{.Name | ToPascal}} activity
func Await{{.Name | ToPascal}}(ctx workflow.Context, input {{if .Options.ByFieldOnly}}{{.ByFieldType}}{{else}}{{$reqType}}{{end}}, opts ...*workflow.ActivityOptions) ({{if .OutputType}}{{.OutputType}}, {{end}}error) {
	{{if .OutputType}}var result {{.OutputType}}{{end}}
	options := workflow.GetActivityOptions(ctx)
	{{- if .Options.TaskQueue}}
	options.TaskQueue = "{{.Options.TaskQueue}}"
	{{- end}}
	{{- if .Options.ScheduleToCloseTimeout}}
	options.ScheduleToCloseTimeout = time.Duration({{.Options.ScheduleToCloseTimeout | durationToNs}})
	{{- end}}
	{{- if .Options.ScheduleToStartTimeout}}
	options.ScheduleToStartTimeout = time.Duration({{.Options.ScheduleToStartTimeout | durationToNs}})
	{{- end}}
	{{- if .Options.StartToCloseTimeout}}
	options.StartToCloseTimeout = time.Duration({{.Options.StartToCloseTimeout | durationToNs}})
	{{- end}}
	{{- if .Options.HeartbeatTimeout}}
	options.HeartbeatTimeout = time.Duration({{.Options.HeartbeatTimeout | durationToNs}})
	{{- end}}
	{{- if .Options.WaitForCancellation}}
	options.WaitForCancellation = {{.Options.WaitForCancellation}}
	{{- end}}
	{{- if .Options.ActivityID}}
	options.ActivityID = "{{.Options.ActivityID}}"
	{{- end}}
	{{- if .Options.DisableEagerExecution}}
	options.DisableEagerExecution = {{.Options.DisableEagerExecution}}
	{{- end}}
	{{- if .Options.MaxRetries}}
	options.RetryPolicy = &temporal.RetryPolicy{
		MaximumAttempts: int32({{.Options.MaxRetries}}),
	}
	{{- end}}
	{{- if .Options.OptionsCallback}}
	// Apply options from callback
	if cbOpts := {{.Options.OptionsCallback}}(input); cbOpts != nil {
		// Merge cbOpts into options
		if cbOpts.TaskQueue != "" { options.TaskQueue = cbOpts.TaskQueue }
		if cbOpts.ScheduleToCloseTimeout != 0 { options.ScheduleToCloseTimeout = cbOpts.ScheduleToCloseTimeout }
		if cbOpts.ScheduleToStartTimeout != 0 { options.ScheduleToStartTimeout = cbOpts.ScheduleToStartTimeout }
		if cbOpts.StartToCloseTimeout != 0 { options.StartToCloseTimeout = cbOpts.StartToCloseTimeout }
		if cbOpts.HeartbeatTimeout != 0 { options.HeartbeatTimeout = cbOpts.HeartbeatTimeout }
		if cbOpts.WaitForCancellation { options.WaitForCancellation = cbOpts.WaitForCancellation }
		if cbOpts.ActivityID != "" { options.ActivityID = cbOpts.ActivityID }
		if cbOpts.RetryPolicy != nil { options.RetryPolicy = cbOpts.RetryPolicy }
		if cbOpts.DisableEagerExecution { options.DisableEagerExecution = cbOpts.DisableEagerExecution }
	}
	{{- end}}

	for _, opt := range opts {
		if opt != nil {
			if opt.TaskQueue != "" {
				options.TaskQueue = opt.TaskQueue
			}
			if opt.ScheduleToCloseTimeout != 0 {
				options.ScheduleToCloseTimeout = opt.ScheduleToCloseTimeout
			}
			if opt.StartToCloseTimeout != 0 {
				options.StartToCloseTimeout = opt.StartToCloseTimeout
			}
			if opt.ScheduleToStartTimeout != 0 {
				options.ScheduleToStartTimeout = opt.ScheduleToStartTimeout
			}
			if opt.HeartbeatTimeout != 0 {
				options.HeartbeatTimeout = opt.HeartbeatTimeout
			}
			if opt.WaitForCancellation {
				options.WaitForCancellation = opt.WaitForCancellation
			}
			if opt.ActivityID != "" {
				options.ActivityID = opt.ActivityID
			}
			if opt.RetryPolicy != nil {
				options.RetryPolicy = opt.RetryPolicy
			}
			if opt.DisableEagerExecution {
				options.DisableEagerExecution = opt.DisableEagerExecution
			}
		}
	}

	ctx = workflow.WithActivityOptions(ctx, options)
	{{- if .Options.ByFieldOnly}}
	req := {{$reqType}}{
		{{.Options.ByField}}: input,
	}
	{{- if .Options.Namespace}}
	err := workflow.ExecuteActivity(ctx, "{{.QualifiedName}}", req).Get(ctx, {{if .OutputType}}&result{{else}}nil{{end}})
	{{- else}}
	err := workflow.ExecuteActivity(ctx, {{if .Receiver}}({{.Receiver}}).{{end}}{{if .Options.GenerateWrapper}}{{if .Options.WrapperPrefix}}{{.Options.WrapperPrefix}}{{end}}{{.Name | ToPascal}}{{else}}{{.OriginalName}}{{end}}, req).Get(ctx, {{if .OutputType}}&result{{else}}nil{{end}})
	{{- end}}
	{{- else}}
	{{- if .Options.Namespace}}
	err := workflow.ExecuteActivity(ctx, "{{.QualifiedName}}", input).Get(ctx, {{if .OutputType}}&result{{else}}nil{{end}})
	{{- else}}
	err := workflow.ExecuteActivity(ctx, {{if .Receiver}}({{.Receiver}}).{{end}}{{if .Options.GenerateWrapper}}{{if .Options.WrapperPrefix}}{{.Options.WrapperPrefix}}{{end}}{{.Name | ToPascal}}{{else}}{{.OriginalName}}{{end}}, input).Get(ctx, {{if .OutputType}}&result{{else}}nil{{end}})
	{{- end}}
	{{- end}}
	return {{if .OutputType}}result, {{end}}err
}

{{- if and .Options.ByField (not .Options.ByFieldOnly)}}
// Await{{.Name | ToPascal}}By{{.Options.ByField}} is a wrapper for the {{.Name | ToPascal}} activity
func Await{{.Name | ToPascal}}By{{.Options.ByField}}(ctx workflow.Context, input {{.ByFieldType}}, opts ...*workflow.ActivityOptions) ({{if .OutputType}}{{.OutputType}}, {{end}}error) {
	req := {{$reqType}}{
		{{.Options.ByField}}: input,
	}
	return Await{{.Name | ToPascal}}(ctx, req, opts...)
}
{{- end}}