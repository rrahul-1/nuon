FROM golang:1.25 AS build-base

RUN rm -f /etc/apt/apt.conf.d/docker-clean

RUN --mount=type=cache,target=/var/cache/apt,id=gobase-apt \
    apt-get update && apt-get install --no-install-recommends -y ca-certificates \
    coreutils \
    make \
    git \
    curl \
    protobuf-compiler \
    libx11-dev \
    jq && rm -rf /var/lib/apt/lists/*

# Get golangci-lint from the official image
FROM golangci/golangci-lint:latest AS golangci

# Back to main build
FROM build-base AS build

# Copy golangci-lint binary from the golangci image
COPY --from=golangci /usr/bin/golangci-lint /usr/bin/

# Configure standard Go paths — must match the cache mount targets below
ENV GOCACHE=/go/pkg/build-cache
ENV GOMODCACHE=/go/pkg/mod
ENV GOPROXY=http://athens.arc-athens.svc.cluster.local:3000|https://proxy.golang.org,direct

WORKDIR /src

# Copy core dependencies (will be overridden in service build)
COPY tools.go go.mod go.sum ./

# Copy in-tree SDKs (required for go.mod replace directives)
COPY sdks ./sdks/

# Download all dependencies into the module cache
RUN go mod download

# Copy and generate package code (common code generation)
COPY pkg pkg
RUN cd pkg && go generate ./...

# Test target for pkg directory
FROM build AS pkg-test
RUN --mount=type=cache,target=/go/pkg/build-cache,id=gobase-build \
    cd pkg && go test -v ./...

# Lint target for pkg directory
FROM build AS pkg-lint
COPY .golangci.yml .
RUN --mount=type=cache,target=/root/.cache/golangci-lint,id=golint-pkg \
    --mount=type=cache,target=/go/pkg/build-cache,id=gobase-build \
    cd pkg && golangci-lint run -c ../.golangci.yml -v

# Final build image that can be referenced
FROM build-base AS final

# Set GOPROXY so all service builds FROM this image inherit it — no ARG needed in downstream Dockerfiles
ENV GOCACHE=/go/pkg/build-cache
ENV GOMODCACHE=/go/pkg/mod
ENV GOPROXY=http://athens.arc-athens.svc.cluster.local:3000|https://proxy.golang.org,direct

COPY --from=build /usr/bin/golangci-lint /usr/bin/golangci-lint
COPY --from=build /src/ /src/

# Bake downloaded modules into the image
COPY --from=build /go/pkg/mod /go/pkg/mod
COPY --from=build /go/pkg/build-cache /go/pkg/build-cache

WORKDIR /src
# Set default CMD
CMD ["bash"]
