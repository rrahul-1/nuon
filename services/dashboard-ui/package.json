{
  "Name": "nuon-dashboard-ui",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "npm run generate-api-types",
    "dev": "next dev -p 4000 --turbo",
    "dev:ladle": "ladle dev",
    "dev:css": "postcss client/styles.css -o dist/styles.css -w",
    "dev:ts": "esbuild client/index.tsx --bundle --outfile=dist/app.js --jsx=automatic --tsconfig=client/tsconfig.json --alias:@=./client --sourcemap --define:process.env.NODE_ENV='\"development\"' --watch=forever",
    "dev:html": "cp client/index.html dist/index.html",
    "dev:bs": "browser-sync start --proxy localhost:${HTTP_PORT:-4040} --files 'dist/**/*' --no-open --port 4001",
    "dev:spa": "npm run dev:html && run-p dev:css dev:ts dev:bs",
    "build": "cross-env NODE_ENV=production next build",
    "build:spa:js": "esbuild client/index.tsx --bundle --outfile=dist/app.js --jsx=automatic --tsconfig=client/tsconfig.json --alias:@=./client --minify --define:process.env.NODE_ENV='\"production\"'",
    "build:spa:css": "cross-env NODE_ENV=production postcss client/styles.css -o dist/styles.css",
    "build:spa": "mkdir -p dist && npm run dev:html && run-p build:spa:js build:spa:css",
    "prebuild": "npm run generate-api-types",
    "generate-api-types": "node ./scripts/generate-api-types.js",
    "generate-api-mocks": "node ./scripts/generate-mocks-with-clean-spec.js",
    "start": "next start -p 4000",
    "start-mock-api": "tsx test/mock-express-api.ts",
    "lint": "next lint",
    "lint:spa": "eslint \"client/**/*.{ts,tsx}\"",
    "fmt": "prettier src",
    "pretest": "npm run generate-api-mocks",
    "test": "vitest run --testTimeout 40000",
    "pretsc": "npm run generate-api-types",
    "tsc": "tsc --noEmit",
    "tsc:spa": "tsc --noEmit --project client/tsconfig.json"
  },
  "dependencies": {
    "@andypf/json-viewer": "^2.1.10",
    "@auth0/nextjs-auth0": "^4.13.0",
    "@dagrejs/dagre": "^1.1.5",
    "@datadog/browser-logs": "^5.16.0",
    "@datadog/browser-rum": "^5.16.0",
    "@monaco-editor/react": "^4.7.0",
    "@phosphor-icons/react": "^2.1.7",
    "@segment/analytics-next": "^1.72.2",
    "@tailwindcss/postcss": "^4.1.13",
    "@tailwindcss/typography": "^0.5.15",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@tanstack/react-table": "^8.20.5",
    "@uiw/react-textarea-code-editor": "^3.0.2",
    "@xyflow/react": "^12.7.0",
    "classnames": "^2.5.1",
    "cronstrue": "^2.52.0",
    "geist": "^1.3.1",
    "hcl2-json-parser": "^1.0.1",
    "hot-shots": "^11.2.0",
    "js-confetti": "^0.13.1",
    "luxon": "^3.4.4",
    "mermaid": "^11.12.1",
    "next": "^15.5.9",
    "react": "^18",
    "react-dom": "^18",
    "react-error-boundary": "^4.1.2",
    "react-icons": "^5.0.1",
    "react-markdown": "^10.1.0",
    "react-router": "^7.13.1",
    "react-syntax-highlighter": "^15.6.1",
    "react-tailwindcss-select": "^1.8.5",
    "showdown": "^2.1.0",
    "uuid": "^11.1.0",
    "yaml": "^2.7.1"
  },
  "devDependencies": {
    "@faker-js/faker": "^8.4.1",
    "@ladle/react": "^5.0.3",
    "@mswjs/http-middleware": "^0.10.2",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^15.0.2",
    "@types/babel__generator": "^7.27.0",
    "@types/babel__template": "^7.4.4",
    "@types/babel__traverse": "^7.20.7",
    "@types/d3-color": "^3.1.3",
    "@types/deep-eql": "^4.0.2",
    "@types/istanbul-lib-coverage": "^2.0.6",
    "@types/istanbul-lib-report": "^3.0.3",
    "@types/jest": "^29.5.12",
    "@types/luxon": "^3.4.2",
    "@types/node": "^20",
    "@types/prop-types": "^15.7.15",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/yargs-parser": "^21.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.0.1",
    "browser-sync": "^3.0.4",
    "cors": "^2.8.5",
    "cross-env": "^7.0.3",
    "d3-color": "^3.1.0",
    "esbuild": "^0.27.3",
    "eslint": "^8",
    "eslint-config-next": "14.1.3",
    "eslint-plugin-import": "^2.31.0",
    "express": "^4.21.1",
    "jsdom": "^24.0.0",
    "msw": "^2.3.1",
    "msw-auto-mock": "^0.18.0",
    "npm-run-all": "^4.1.5",
    "openapi-typescript": "^6.7.6",
    "postcss": "^8.5.6",
    "postcss-cli": "^11.0.1",
    "prettier": "^3.2.5",
    "tailwindcss": "^4.1.13",
    "tsx": "^4.19.3",
    "typescript": "^5",
    "vite-tsconfig-paths": "^4.3.2",
    "vitest": "^3.1.1"
  },
  "optionalDependencies": {
    "@next/swc-darwin-arm64": "15.3.3",
    "@next/swc-darwin-x64": "15.3.3",
    "@next/swc-linux-x64-gnu": "15.3.3",
    "@next/swc-linux-x64-musl": "15.3.3"
  }
}
