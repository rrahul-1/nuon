{
  "Name": "nuon-dashboard-ui",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bun scripts/clean-dist.js && bun run --parallel dev:css dev:server generate-api-types",
    "dev:ts": "bun build client/index.tsx --outdir=dist/assets --entry-naming='app.[ext]' --sourcemap --define 'process.env.NODE_ENV=\"development\"' --watch",
    "dev:ladle": "ladle dev",
    "dev:css": "bun scripts/build-css.js --watch",
    "dev:server": "bun scripts/dev-server.js",
    "build:js": "bun build client/index.tsx --outdir=dist/assets --entry-naming='[name]-[hash].[ext]' --chunk-naming='[name]-[hash].[ext]' --splitting --minify --define 'process.env.NODE_ENV=\"production\"' --metafile=dist/meta.json",
    "build:css": "NODE_ENV=production bun scripts/build-css.js",
    "build": "bun scripts/clean-dist.js && bun run --parallel build:js build:css && bun scripts/hash-assets.js && bun scripts/compress-assets.js",
    "generate-api-types": "bun ./scripts/generate-api-types.js",
    "lint": "oxlint -c client/.oxlintrc.json client/",
    "fmt": "prettier client",
    "test": "bun test --timeout 40000",
    "pretsc": "bun run generate-api-types",
    "tsc": "tsc --noEmit --project client/tsconfig.json",
    "test:e2e": "playwright test -c e2e/playwright.config.ts",
    "test:e2e:ui": "playwright test -c e2e/playwright.config.ts --ui",
    "test:e2e:headed": "playwright test -c e2e/playwright.config.ts --headed"
  },
  "dependencies": {
    "@andypf/json-viewer": "2.2.0",
    "@codemirror/lang-json": "6.0.2",
    "@codemirror/language": "6.12.3",
    "@codemirror/legacy-modes": "6.5.2",
    "@dagrejs/dagre": "1.1.5",
    "@datadog/browser-logs": "5.35.1",
    "@datadog/browser-rum": "5.35.1",
    "@dnd-kit/core": "6.3.1",
    "@dnd-kit/sortable": "10.0.0",
    "@dnd-kit/utilities": "3.2.2",
    "@phosphor-icons/react": "2.1.10",
    "@segment/analytics-next": "1.81.1",
    "@tanstack/react-query": "5.90.21",
    "@tanstack/react-query-devtools": "5.91.3",
    "@tanstack/react-table": "8.21.3",
    "@uiw/react-codemirror": "4.25.9",
    "@xyflow/react": "12.8.2",
    "cronstrue": "2.59.0",
    "html-to-image": "1.11.13",
    "js-confetti": "0.13.1",
    "luxon": "3.7.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-icons": "5.5.0",
    "react-markdown": "10.1.0",
    "react-router": "7.13.1",
    "react-syntax-highlighter": "15.6.1",
    "recharts": "3.8.1",
    "yaml": "2.8.1"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "18.0.1",
    "@ladle/react": "5.0.3",
    "@playwright/test": "1.59.1",
    "@tailwindcss/postcss": "4.1.13",
    "@tailwindcss/typography": "0.5.16",
    "@testing-library/jest-dom": "6.6.4",
    "@testing-library/react": "15.0.7",
    "@types/bun": "1.3.13",
    "@types/react": "18.3.23",
    "@types/react-dom": "18.3.7",
    "autoprefixer": "10.5.0",
    "oxlint": "1.64.0",
    "msw": "2.10.4",
    "openapi-typescript": "6.7.6",
    "postcss": "8.5.6",
    "prettier": "3.6.2",
    "tailwindcss": "4.1.13",
    "typescript": "5.9.2"
  }
}
