{
  "Name": "nuon-dashboard-ui",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "mkdir -p dist && npm run dev:html && run-p dev:css dev:ts dev:bs generate-api-types",
    "dev:ladle": "ladle dev",
    "dev:css": "postcss client/styles.css -o dist/styles.css -w",
    "dev:ts": "esbuild client/index.tsx --bundle --outfile=dist/app.js --jsx=automatic --tsconfig=client/tsconfig.json --alias:@=./client --sourcemap --define:process.env.NODE_ENV='\"development\"' --watch=forever",
    "dev:html": "cp client/index.html dist/index.html",
    "dev:bs": "browser-sync start --proxy localhost:${HTTP_PORT:-4000} --files 'dist/**/*' --no-open --port $((${HTTP_PORT:-4000}+1))",
    "build:js": "esbuild client/index.tsx --bundle --outdir=dist/assets --entry-names=[name]-[hash] --jsx=automatic --tsconfig=client/tsconfig.json --alias:@=./client --minify --define:process.env.NODE_ENV='\"production\"' --metafile=dist/meta.json",
    "build:css": "cross-env NODE_ENV=production postcss client/styles.css -o dist/styles.css",
    "build": "mkdir -p dist/assets && run-p build:js build:css && node scripts/hash-assets.js",
    "generate-api-types": "node ./scripts/generate-api-types.js",
    "lint": "eslint \"client/**/*.{ts,tsx}\"",
    "fmt": "prettier client",
    "test": "vitest run --testTimeout 40000",
    "pretsc": "npm run generate-api-types",
    "tsc": "tsc --noEmit --project client/tsconfig.json",
    "test:e2e": "playwright test -c e2e/playwright.config.ts",
    "test:e2e:ui": "playwright test -c e2e/playwright.config.ts --ui",
    "test:e2e:headed": "playwright test -c e2e/playwright.config.ts --headed"
  },
  "dependencies": {
    "@andypf/json-viewer": "^2.1.10",
    "@dagrejs/dagre": "^1.1.5",
    "@datadog/browser-logs": "^5.16.0",
    "@datadog/browser-rum": "^5.16.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@monaco-editor/react": "^4.7.0",
    "@phosphor-icons/react": "^2.1.7",
    "@segment/analytics-next": "^1.72.2",
    "@tailwindcss/postcss": "^4.1.13",
    "@tailwindcss/typography": "^0.5.15",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@tanstack/react-table": "^8.20.5",
    "@uiw/react-textarea-code-editor": "^3.0.2",
    "@xyflow/react": "^12.7.0",
    "classnames": "^2.5.1",
    "cronstrue": "^2.52.0",
    "hcl2-json-parser": "^1.0.1",
    "html-to-image": "^1.11.13",
    "js-confetti": "^0.13.1",
    "luxon": "^3.4.4",
    "mermaid": "^11.12.1",
    "react": "^18",
    "react-dom": "^18",
    "react-error-boundary": "^4.1.2",
    "react-icons": "^5.0.1",
    "react-markdown": "^10.1.0",
    "react-router": "^7.13.1",
    "react-syntax-highlighter": "^15.6.1",
    "react-tailwindcss-select": "^1.8.5",
    "showdown": "^2.1.0",
    "uuid": "^11.1.0",
    "yaml": "^2.7.1"
  },
  "devDependencies": {
    "@faker-js/faker": "^8.4.1",
    "@ladle/react": "^5.0.3",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^15.0.2",
    "@types/babel__generator": "^7.27.0",
    "@types/babel__template": "^7.4.4",
    "@types/babel__traverse": "^7.20.7",
    "@types/d3-color": "^3.1.3",
    "@types/deep-eql": "^4.0.2",
    "@types/istanbul-lib-coverage": "^2.0.6",
    "@types/istanbul-lib-report": "^3.0.3",
    "@types/jest": "^29.5.12",
    "@types/luxon": "^3.4.2",
    "@types/node": "^20",
    "@types/prop-types": "^15.7.15",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/yargs-parser": "^21.0.3",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.0.1",
    "browser-sync": "^3.0.4",
    "cors": "^2.8.5",
    "cross-env": "^7.0.3",
    "d3-color": "^3.1.0",
    "esbuild": "^0.27.3",
    "eslint": "^8",
    "eslint-plugin-import": "^2.31.0",
    "express": "^4.21.1",
    "jsdom": "^24.0.0",
    "msw": "^2.3.1",
    "npm-run-all": "^4.1.5",
    "openapi-typescript": "^6.7.6",
    "postcss": "^8.5.6",
    "postcss-cli": "^11.0.1",
    "prettier": "^3.2.5",
    "tailwindcss": "^4.1.13",
    "tsx": "^4.19.3",
    "typescript": "^5",
    "vite-tsconfig-paths": "^4.3.2",
    "vitest": "^3.1.1",
    "@playwright/test": "^1.52.0"
  }
}
