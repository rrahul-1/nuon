{
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],
    "target": "ES2017",
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": false,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "paths": {
      "@/*": ["./*"],
      "@test/*": ["../test/*"]
    },
    "types": ["@testing-library/jest-dom"]
  },
  "include": ["./**/*.ts", "./**/*.tsx"],
  "exclude": [
    "components/admin/**",
    "components/stacks/StackLinks.tsx"
  ]
}
