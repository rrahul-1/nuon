import type { Metadata } from 'next'
import { Suspense } from 'react'
import { notFound } from 'next/navigation'
import { ErrorBoundary } from '@/components/common/ErrorBoundary'
import { HeadingGroup } from '@/components/common/HeadingGroup'
import { ID } from '@/components/common/ID'
import { Text } from '@/components/common/Text'
import { Link } from '@/components/common/Link'
import { Icon } from '@/components/common/Icon'
import { LabeledValue } from '@/components/common/LabeledValue'
import { Time } from '@/components/common/Time'
import { Card } from '@/components/common/Card'
import { Badge } from '@/components/common/Badge'
import { PageSection } from '@/components/layout/PageSection'
import { Breadcrumbs } from '@/components/navigation/Breadcrumb'
import { getApp, getAppBranch, getOrg, getVCSConnections } from '@/lib'
import type { TPageProps } from '@/types'
import { BranchDetailActions } from './branch-detail-actions'
import { BranchConfigHistoryTable } from './branch-config-history-table'
import { BranchWorkflowRunsTable } from './branch-workflow-runs-table'

type TBranchPageProps = TPageProps<'org-id' | 'app-id' | 'branch-id'>

export async function generateMetadata({
  params,
}: TBranchPageProps): Promise<Metadata> {
  const { ['org-id']: orgId, ['app-id']: appId, ['branch-id']: branchId } =
    await params
  const { data: branch } = await getAppBranch({ appId, branchId, orgId })

  return {
    title: `${branch?.name || 'Branch'} | Branches | Nuon`,
  }
}

export default async function AppBranchDetailPage({
  params,
}: TBranchPageProps) {
  const { ['org-id']: orgId, ['app-id']: appId, ['branch-id']: branchId } =
    await params

  const [
    { data: branch, error },
    { data: app },
    { data: org },
    { data: vcsConnections },
  ] = await Promise.all([
    getAppBranch({ appId, branchId, orgId, latestConfig: true }),
    getApp({ appId, orgId }),
    getOrg({ orgId }),
    getVCSConnections({ orgId }),
  ])

  if (error || !branch) {
    notFound()
  }

  // Get current config (most recent)
  const currentConfig =
    branch.configs && branch.configs.length > 0
      ? branch.configs.sort(
          (a, b) => (b.config_number || 0) - (a.config_number || 0)
        )[0]
      : undefined

  return (
    <PageSection isScrollable>
      <Breadcrumbs
        breadcrumbs={[
          {
            path: `/${orgId}`,
            text: org?.name || '',
          },
          {
            path: `/${orgId}/apps`,
            text: 'Apps',
          },
          {
            path: `/${orgId}/apps/${appId}`,
            text: app?.name || '',
          },
          {
            path: `/${orgId}/apps/${appId}/branches`,
            text: 'Branches',
          },
          {
            path: `/${orgId}/apps/${appId}/branches/${branchId}`,
            text: branch?.name || '',
          },
        ]}
      />

      {/* Page Header */}
      <div className="flex items-start justify-between mb-6">
        <HeadingGroup>
          <Text variant="h3" weight="stronger">
            {branch.name}
          </Text>
          <ID>{branch.id}</ID>
          <Text variant="subtext" theme="info">
            Created{' '}
            <Time time={branch?.created_at} format="relative" />
          </Text>
        </HeadingGroup>

        <BranchDetailActions
          branch={branch}
          currentConfig={currentConfig}
          vcsConnections={vcsConnections || []}
          appId={appId}
          orgId={orgId}
        />
      </div>

      {/* Current Configuration Section */}
      <Card className="mb-6">
        <div className="p-6">
          <div className="flex items-center justify-between mb-4">
            <Text variant="h4" weight="strong">
              Current Configuration
            </Text>
            {currentConfig && (
              <Badge theme="info" size="sm">
                v{currentConfig.config_number}
              </Badge>
            )}
          </div>

          {!currentConfig ? (
            <div className="text-center py-8">
              <Text variant="body" theme="neutral">
                No configuration yet. Create your first configuration to get started.
              </Text>
            </div>
          ) : (
            <div className="space-y-6">
              <div className="grid grid-cols-1 md:grid-cols-3 gap-4">
                <LabeledValue label="Version">
                  <Text variant="base">v{currentConfig.config_number}</Text>
                </LabeledValue>

                <LabeledValue label="Created">
                  <Time time={currentConfig.created_at} format="relative" />
                </LabeledValue>

                <LabeledValue label="Install Groups">
                  <Text variant="base">
                    {currentConfig.install_groups?.length || 0} group
                    {currentConfig.install_groups?.length !== 1 ? 's' : ''}
                  </Text>
                </LabeledValue>
              </div>

              {currentConfig.connected_github_vcs_config && (
                <div className="border-t pt-4">
                  <Text variant="base" weight="strong" className="mb-3">
                    VCS Configuration
                  </Text>
                  <div className="space-y-2">
                    <div className="flex items-start gap-2">
                      <Text variant="subtext" theme="neutral" className="w-32">
                        Repository:
                      </Text>
                      <Text variant="base">
                        {currentConfig.connected_github_vcs_config.repo}
                      </Text>
                    </div>
                    <div className="flex items-start gap-2">
                      <Text variant="subtext" theme="neutral" className="w-32">
                        Branch:
                      </Text>
                      <code className="text-xs bg-gray-100 dark:bg-gray-800 px-2 py-1 rounded">
                        {currentConfig.connected_github_vcs_config.branch}
                      </code>
                    </div>
                    <div className="flex items-start gap-2">
                      <Text variant="subtext" theme="neutral" className="w-32">
                        Directory:
                      </Text>
                      <Text variant="base">
                        {currentConfig.connected_github_vcs_config.directory || '.'}
                      </Text>
                    </div>
                    {currentConfig.connected_github_vcs_config.path_filter && (
                      <div className="flex items-start gap-2">
                        <Text variant="subtext" theme="neutral" className="w-32">
                          Path Filter:
                        </Text>
                        <code className="text-xs bg-gray-100 dark:bg-gray-800 px-2 py-1 rounded">
                          {currentConfig.connected_github_vcs_config.path_filter}
                        </code>
                      </div>
                    )}
                  </div>
                </div>
              )}

              {currentConfig.install_groups && currentConfig.install_groups.length > 0 && (
                <div className="border-t pt-4">
                  <Text variant="base" weight="strong" className="mb-3">
                    Install Groups
                  </Text>
                  <div className="space-y-3">
                    {currentConfig.install_groups.map((group, idx) => (
                      <div
                        key={group.id || idx}
                        className="p-3 bg-gray-50 dark:bg-gray-900 rounded-md"
                      >
                        <div className="flex items-center justify-between mb-2">
                          <Text variant="base" weight="strong">
                            {idx + 1}. {group.name}
                          </Text>
                          <div className="flex items-center gap-2">
                            {group.requires_approval && (
                              <Badge theme="warning" size="sm">
                                Requires Approval
                              </Badge>
                            )}
                            {group.rollback_on_failure && (
                              <Badge theme="info" size="sm">
                                Rollback on Failure
                              </Badge>
                            )}
                          </div>
                        </div>
                        <div className="grid grid-cols-2 gap-2 text-sm">
                          <div>
                            <Text variant="subtext" theme="neutral">
                              Installs: {group.install_ids?.length || 0}
                            </Text>
                          </div>
                          <div>
                            <Text variant="subtext" theme="neutral">
                              Max Parallel: {group.max_parallel || 1}
                            </Text>
                          </div>
                        </div>
                      </div>
                    ))}
                  </div>
                </div>
              )}
            </div>
          )}
        </div>
      </Card>

      {/* Configuration History Section */}
      <div className="mb-6">
        <div className="flex items-center justify-between mb-4">
          <Text variant="h4" weight="strong">
            Configuration History
          </Text>
          <Link href={`/${orgId}/apps/${appId}/branches/${branchId}/configs`}>
            View All <Icon variant="CaretRightIcon" />
          </Link>
        </div>
        <ErrorBoundary fallback={<>Error loading configuration history</>}>
          <Suspense fallback={<div>Loading configuration history...</div>}>
            <BranchConfigHistoryTable
              appId={appId}
              branchId={branchId}
              orgId={orgId}
              currentConfigId={currentConfig?.id}
            />
          </Suspense>
        </ErrorBoundary>
      </div>

      {/* Workflow Runs Section */}
      <div>
        <div className="flex items-center justify-between mb-4">
          <Text variant="h4" weight="strong">
            Workflow Runs
          </Text>
          <Link href={`/${orgId}/apps/${appId}/branches/${branchId}/runs`}>
            View All <Icon variant="CaretRightIcon" />
          </Link>
        </div>
        <ErrorBoundary fallback={<>Error loading workflow runs</>}>
          <Suspense fallback={<div>Loading workflow runs...</div>}>
            <BranchWorkflowRunsTable
              appId={appId}
              branchId={branchId}
              orgId={orgId}
            />
          </Suspense>
        </ErrorBoundary>
      </div>
    </PageSection>
  )
}